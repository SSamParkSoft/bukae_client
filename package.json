{
  "name": "bookae_client",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter bookae_creator dev",
    "dev:creator": "pnpm --filter bookae_creator dev",
    "dev:viewer": "pnpm --filter bukae_viewer dev",
    "dev:analyze": "pnpm --filter bukae_analyze dev",
    "dev:all": "pnpm --parallel --filter './apps/*' dev",
    "build": "bash scripts/auto-build-fix.sh",
    "build:raw": "pnpm --filter bookae_creator build",
    "build:creator": "pnpm --filter bookae_creator build",
    "build:viewer": "pnpm --filter bukae_viewer build",
    "build:analyze": "pnpm --filter bukae_analyze build",
    "build:all": "pnpm --filter './apps/*' build",
    "start": "pnpm --filter bookae_creator start",
    "start:creator": "pnpm --filter bookae_creator start",
    "start:viewer": "pnpm --filter bukae_viewer start",
    "start:analyze": "pnpm --filter bukae_analyze start",
    "lint": "pnpm --filter './apps/*' lint",
    "typecheck": "pnpm --filter './apps/*' typecheck",
    "seed-demo": "pnpm --filter bookae_creator run seed-demo",
    "test": "pnpm --filter bookae_creator test",
    "test:watch": "pnpm --filter bookae_creator test:watch"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "next": "^16.2.3",
    "playwright": "^1.58.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.8",
      "js-yaml": ">=4.1.1",
      "minimatch": "10.2.4",
      "ajv": "6.14.0",
      "flatted": ">=3.4.2",
      "picomatch": ">=2.3.2 <4 || >=4.0.4",
      "@tootallnate/once": ">=3.0.1",
      "brace-expansion": ">=5.0.5",
      "@xmldom/xmldom": ">=0.9.10",
      "vite": "8.0.7",
      "protobufjs": ">=7.5.5",
      "postcss": ">=8.5.10"
    }
  }
}
